LLM_PROVIDER=deepinfra
LLM_MODEL=nvidia/Nemotron-3-Nano-30B-A3B
DEEPINFRA_API_KEY=your_deepinfra_api_key_here
# Backward-compatible alias:
# DEEPIN_API_KEY=your_deepinfra_api_key_here
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Orchestrator planner (Gemma via DeepInfra OpenAI-compatible endpoint)
ORCHESTRATOR_LLM_PROVIDER=google_gemma
ORCHESTRATOR_MODEL=google/gemma-3-27b-it
ORCHESTRATOR_BASE_URL=https://api.deepinfra.com/v1/openai
ORCHESTRATOR_API_KEY=
ORCHESTRATOR_TEMPERATURE=0.3
ORCHESTRATOR_MAX_TOKENS=1024
RUN_LIVE_LLM_TESTS=0
