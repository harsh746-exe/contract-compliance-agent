# =============================================================
# Compliance Agent — Environment Configuration
# =============================================================
# Choose ONE provider section below and fill in the values.
# Then copy this file to .env:  cp .env.example .env

# --- Option A: Ollama (local, no API key needed) ---------------
# Install Ollama first: https://ollama.com  or run setup_ollama.sh
# Then: ollama pull llama3.1:8b && ollama pull llama3.2:3b
#
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1:8b
# LLM_FAST_MODEL=llama3.2:3b
# LLM_STANDARD_MODEL=llama3.1:8b
# LLM_STRONG_MODEL=llama3.1:8b
# ORCHESTRATOR_LLM_PROVIDER=ollama
# ORCHESTRATOR_MODEL=llama3.2:3b
# ORCHESTRATOR_BASE_URL=http://localhost:11434/v1
# LLM_TIMEOUT=120

# --- Option B: DeepInfra (cloud, requires API key) -------------
# LLM_PROVIDER=deepinfra
# DEEPIN_API_KEY=your_deepinfra_api_key_here

# --- Option C: OpenAI (cloud, requires API key) ----------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# --- Testing ---------------------------------------------------
RUN_LIVE_LLM_TESTS=0